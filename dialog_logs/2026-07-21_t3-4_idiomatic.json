�� ����� ��� �������� �����. - ���������\n    // ����� min � max, ��������������������� �� + � - ������� double.\n    double minimum = std::numeric_limits<double>::lowest();\n    double maximum = std::numeric_limits<double>::max();\n    Point max_border{minimum, minimum, minimum};\n    Point min_border{maximum, maximum, maximum};\n    // � ����� ���������\n    Point center{};\n\n    for (const auto& p : points) {\n\n        if (p.x > max_border.x)\n            max_border.x = p.x;\n        if (p.y > max_border.y)\n            max_border.y = p.y;\n        if (p.z > max_border.z)\n            max_border.z = p.z;\n\n        if (p.x < min_border.x)\n            min_border.x = p.x;\n        if (p.y < min_border.y)\n            min_border.y = p.y;\n        if (p.z < min_border.z)\n            min_border.z = p.z;\n\n        center.x += p.x;\n        center.y += p.y;\n        center.z += p.z;\n    }\n\n    // ������� ����� ��������� �� ���-�� ��� ��������� � �����\n    center.x = center.x / points.size();\n    center.y = center.y / points.size();\n    center.z = center.z / points.size();\n\n    // ���������� �������� ���������� �� ����� �� ���������\n    double dist = 0;\n    for (const auto& p : points) {\n        dist += std::hypot(p.x - center.x, p.y - center.y, p.z - center.z);\n    }\n    dist = dist / points.size();\n\n    // ����� ���-�� �����, ������ ���������������, �����. ��������� � ����. �����. �� ����\n    std::print(\"���������� �����: {}\\n\", points.size());\n\n    std::print(\n        \"���������� �������. ��������������� x: [ {:.3f}; {:.3f} ] y: [ {:.3f}; {:.3f} ] z: [ {:.3f}; {:.3f} ]\\n\",\n        min_border.x, max_border.x, min_border.y, max_border.y, min_border.z, max_border.z);\n\n    std::print(\"���������� ��������� x: {:.3f}, y: {:.3f}, z: {:.3f}\\n\", center.x, center.y, center.z);\n\n    std::print(\"������� ���������� �� ����� �� ���������: {:.3f}\\n\", dist);\n\n    return 0;\n}",
