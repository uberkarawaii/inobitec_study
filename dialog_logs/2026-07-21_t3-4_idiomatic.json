 end_ptr;\n        double d[3];\n        int j = 0;\n        while (j < 3) {\n            d[j] = strtod(start_ptr, &end_ptr);\n            if (end_ptr == start_ptr || (*end_ptr != ' ' && *end_ptr != '\\0')) {\n                fprintf(stderr, \"������ %d. ���������� ������: %s\\n\", i, clean_s);\n                free(s);\n                s = NULL;\n                return data;\n            }\n            start_ptr = end_ptr;\n            ++j;\n        }\n\n        // ������������� � ��������\n        center.x += d[0];\n        center.y += d[1];\n        center.z += d[2];\n\n        // ������� x y z �������� � ����� ������\n        points[points_size] = (struct Point){.x = d[0], .y = d[1], .z = d[2]};\n        points_size++;\n        // ���� ������ >= ����������� �� ���� ��������� �����������\n        if (points_size >= points_capacity) {\n            points_capacity *= 2;\n            struct Point* tmp = realloc(points, points_capacity * sizeof(*tmp));\n            if (!tmp) {\n                fprintf(stderr, \"������ ��� ��������� ������\\n\");\n                free(s);\n                exit(io_fail);\n            }\n            points = tmp;\n        }\n\n        // ������������ s �.�. � �� ��������� ����� ������\n        free(s);\n        s = NULL;\n    }\n\n    // ���� ����� ������� ����� ������� == 0 �� ������� ������ �� ����\n    if (points_size == 0) {\n        fprintf(stderr, \"������� ������ �����������\\n\");\n        free(s);\n        return no_input;\n    }\n\n    // ������� ����������� � ��������� ����� �� ���-�� �����\n    center.x /= points_size;\n    center.y /= points_size;\n    center.z /= points_size;\n\n    // ������� - �������� � ���������\n    double max[3] = {points[0].x, points[0].y, points[0].z};\n    double min[3] = {points[0].x, points[0].y, points[0].z};\n    // ������� ���������� �� ���������\n    double d = 0;\n\n    i = 0;\n    for (; i < points_size; ++i) {\n        if (max[0] < points[i].x)\n            max[0] = points[i].x;\n        if (max[1] < points[i].y)\n            max[1] = points[i].y;\n        if (max[2] < points[i].z)\n            max[2] = points[i].z;\n\n        if (min[0] > points[i].x)\n            min[0] = points[i].x;\n        if (min[1] > points[i].y)\n            min[1] = points[i].y;\n        if (min[2] > points[i].z)\n            min[2] = points[i].z;\n\n        d += sqrt((points[i].x - center.x) * (points[i].x - center.x) +\n                  (points[i].y - center.y) * (points[i].y - center.y) +\n                  (points[i].z - center.z) * (points[i].z - center.z));\n    }\n\n    // ������� ������������ ���������� �� ���-�� �����\n    d /= points_size;\n\n    // ����� ����������\n    printf(\"���������� �����: %d\\n\", points_size);\n    printf(\"���������� �������. ��������������� x: [ %.3f; %.3f ] y: [ %.3f; %.3f ] z: [ %.3f; %.3f ]\\n\", min[0],\n           max[0], min[1], max[1], min[2], max[2]);\n    printf(\"���������� ��������� x: %.3f, y: %.3f, z: %.3f\\n\", center.x, center.y, center.z);\n    printf(\"������� ���������� �� ����� �� ���������: %.3f\\n\", d);\n\n    free(s);\n    free(points);\n    return 0;\n}",
