                "text": "#include <ctype.h>\n#include <locale.h>\n#include <math.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\n#include \"..\\common\\exit_codes.h\"\n#include \"..\\common\\string_utils.h\"\n\nstruct Point {\n    double x;\n    double y;\n    double z;\n};\n\nint main() {\n\n    int len;\n    char* s = NULL;\n\n    // ������ ����� � �������� ��������� ������\n    int points_size = 0, points_capacity = 1;\n    struct Point* points = malloc(sizeof(struct Point));\n    if (!points) {\n        fprintf(stderr, \"�� ������� �������� ������\\n\");\n        return io_fail;\n    }\n\n    // ��������\n    struct Point center = {.x = 0, .y = 0, .z = 0};\n\n    // ������� ��� ������ ������\n    int i = 0;\n    while (1) {\n        // ������� ������\n        s = get_string(&len);\n        ++i;\n        // ����� ����� ��������� �������� �� �������� � IO\n        if (len == -1 && ferror(stdin)) {\n            fprintf(stderr, \"������ � IO\\n\");\n            free(s);\n            s = NULL;\n            return io_fail;\n        }\n\n        if (len == -1) {\n            free(s);\n            s = NULL;\n            break;\n        }\n\n        // ������� �������� �� �����\n        char* clean_s = trim_string(s, &len);\n        // ���� ����� ������� ������ �����, �������, ��� � ����. ������\n        if (strlen(clean_s) == 0) {\n            free(s);\n            s = NULL;\n            continue;\n        }\n\n        // ���������� �������� �������� ����� � ������ � ��������� ������. ���� ��� �� ���������,\n        // ������ ����� ���� ���� ��� ��������, ������� ����� ����������� ����������\n        // ����� - ��� �� ���������� ���������\n        if (strchr(clean_s, ' ') == strrchr(clean_s, ' ')) {\n            fprintf(stderr, \"������ %d. ��������� ���������� X Y Z. ��������: %s\\n\", i, clean_s);\n            free(s);\n            s = NULL;\n            return data;\n        }\n        // ������������� ����� � ��������� ������\n        char* start_ptr = clean_s;\n        char* end_ptr;\n        double d[3];\n        int j = 0;\n        while (j < 3) {\n            d[j] = strtod(start_ptr, &end_ptr);\n            if (end_ptr == start_ptr || (*end_ptr != ' ' && *end_ptr != '\\0')) {\n                fprintf(stderr, \"������ %d. ���������� ������: %s\\n\", i, clean_s);\n                free(s);\n                s = NULL;\n                return data;\n            }\n            start_ptr = end_ptr;\n            ++j;\n        }\n\n        // ������������� � ��������\n        center.x += d[0];\n        center.y += d[1];\n        center.z += d[2];\n\n        // ������� x y z �������� � ����� ������\n        points[points_size] = (struct Point){.x = d[0], .y = d[1], .z = d[2]};\n        points_size++;\n        // ���� ������ >= ����������� �� ���� ��������� �����������\n        if (points_size >= points_capacity) {\n            points_capacity *= 2;\n            struct Point* tmp = realloc(points, points_capacity * sizeof(*tmp));\n            if (!tmp) {\n                fprintf(stderr, \"������ ��� ��������� ������\\n\");\n                free(s);\n                exit(io_fail);\n            }\n            points = tmp;\n        }\n\n        // ������������ s �.�. � �� ��������� ����� ������\n        free(s);\n        s = NULL;\n    }\n\n    // ���� ����� ������� ����� ������� == 0 �� ������� ������ �� ����\n    if (points_size == 0) {\n        fprintf(stderr, \"������� ������ �����������\\n\");\n        free(s);\n        return no_input;\n    }\n\n    // ������� ����������� � ��������� ����� �� ���-�� �����\n    center.x /= points_size;\n    center.y /= points_size;\n    center.z /= points_size;\n\n    // ������� - �������� � ���������\n    double max[3] = {points[0].x, points[0].y, points[0].z};\n    double min[3] = {points[0].x, points[0].y, points[0].z};\n    // ������� ���������� �� ���������\n    double d = 0;\n\n    i = 0;\n    for (; i < points_size; ++i) {\n        if (max[0] < points[i].x)\n            max[0] = points[i].x;\n        if (max[1] < points[i].y)\n            max[1] = points[i].y;\n        if (max[2] < points[i].z)\n            max[2] = points[i].z;\n\n        if (min[0] > points[i].x)\n            min[0] = points[i].x;\n        if (min[1] > points[i].y)\n            min[1] = points[i].y;\n        if (min[2] > points[i].z)\n            min[2] = points[i].z;\n\n        d += sqrt((points[i].x - center.x) * (points[i].x - center.x) +\n                  (points[i].y - center.y) * (points[i].y - center.y) +\n                  (points[i].z - center.z) * (points[i].z - center.z));\n    }\n\n    // ������� ������������ ���������� �� ���-�� �����\n    d /= points_size;\n\n    // ����� ����������\n    printf(\"���������� �����: %d\\n\", points_size);\n    printf(\"���������� �������. ��������������� x: [ %.3f; %.3f ] y: [ %.3f; %.3f ] z: [ %.3f; %.3f ]\\n\", min[0],\n           max[0], min[1], max[1], min[2], max[2]);\n    printf(\"���������� ��������� x: %.3f, y: %.3f, z: %.3f\\n\", center.x, center.y, center.z);\n    printf(\"������� ���������� �� ����� �� ���������: %.3f\\n\", d);\n\n    free(s);\n    free(points);\n    return 0;\n}",
